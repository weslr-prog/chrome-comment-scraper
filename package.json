{
  "name": "chrome-comment-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight Chrome extension for scraping visible Chrome Web Store reviews and summarizing likes and dislikes.",
  "scripts": {
    "check": "node scripts/check.mjs",
    "scrape": "node scripts/scrape-reviews.mjs",
    "summarize": "node scripts/summarize-reviews.mjs",
    "analyze": "node scripts/analyze-reviews.mjs",
    "analyze:ultimate-car": "node scripts/analyze-reviews.mjs --url https://chromewebstore.google.com/detail/ultimate-car-driving-game/aomkpefnllinimbhddlfhelelngakbbn/reviews",
    "ui": "node scripts/ui-server.mjs"
  },
  "dependencies": {
    "playwright-core": "^1.52.0"
  }
}
